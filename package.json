{
  "name": "clipper-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"next,api\" -c \"cyan,green\" \"npm run dev:next\" \"npm run dev:backend\"",
    "dev:next": "next dev",
    "dev:backend": "backend/venv/bin/uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "next build",
    "start": "concurrently \"next start\" \"uvicorn backend.main:app --host 0.0.0.0 --port 8000\"",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "@tailwindcss/postcss": "^4.0.0"
  }
}
